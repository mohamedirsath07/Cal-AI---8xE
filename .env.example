# CalAI Environment Configuration

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_API_TIMEOUT=30000

# AI/ML Configuration
EXPO_PUBLIC_AI_MODEL=vision-v1
EXPO_PUBLIC_CONFIDENCE_THRESHOLD=0.8

# Analytics
EXPO_PUBLIC_ENABLE_ANALYTICS=true
EXPO_PUBLIC_ANALYTICS_ID=

# Feature Flags
EXPO_PUBLIC_ENABLE_CAMERA=true
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true
EXPO_PUBLIC_ENABLE_CLOUD_SYNC=false
EXPO_PUBLIC_ENABLE_HEALTHKIT=true

# Development
DEBUG=false
EXPO_PUBLIC_LOG_LEVEL=info

# App Version
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_BUILD_NUMBER=1

# Notifications
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true

# Database
EXPO_PUBLIC_DATABASE_TYPE=sqlite
